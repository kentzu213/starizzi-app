{
  "name": "@openclaw/cli",
  "version": "0.1.0",
  "description": "CLI tool for building and packaging OpenClaw extensions (.ocx)",
  "type": "module",
  "bin": {
    "openclaw": "dist/bin/openclaw.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "dev": "tsx src/bin/openclaw.ts"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "openclaw",
    "extension",
    "cli",
    "ocx"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/archiver": "^6.0.2",
    "@types/prompts": "^2.4.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.23.1",
    "rimraf": "^5.0.0"
  }
}
