# Izzi OpenClaw Desktop — environment example. Copy to .env (gitignored).
# NEVER commit real keys. izzi- keys are secrets; NEXT_PUBLIC / anon values are public.

# ── Backend / auth (existing) ──
OPENCLAW_API_URL=https://api.izziapi.com
OPENCLAW_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
OPENCLAW_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# ── AI Branching Graph Workspace — Izzi via OpenAI-compatible gateway ──
# The graph agent (chat + branch classifier) calls Izzi through the main process.
# The key stays in the main process and is never exposed to the renderer.
OPENAI_BASE_URL=https://api.izziapi.com/v1
OPENAI_API_KEY=izzi-YOUR_KEY_HERE
IZZI_MODEL=auto

# Optional: if the app is wired to the Anthropic SDK instead of OpenAI-compatible.
# ANTHROPIC_BASE_URL=https://api.izziapi.com
# ANTHROPIC_API_KEY=izzi-YOUR_KEY_HERE
