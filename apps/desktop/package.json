{
  "name": "@openclaw/desktop",
  "version": "1.1.4",
  "private": true,
  "description": "Izzi OpenClaw Desktop App - Electron",
  "author": "kentzu213",
  "homepage": "https://izziapi.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/kentzu213/starizzi-app.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:main\" \"pnpm dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:all": "pnpm build && electron-builder --win --mac",
    "clean": "rimraf dist out release",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:smoke": "vitest run src/**/*.smoke.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@xyflow/react": "^12.11.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "fast-check": "^4.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "extends": "electron-builder.json"
  }
}
