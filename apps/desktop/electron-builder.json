{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.izziapi.openclaw",
  "productName": "Izzi OpenClaw",
  "copyright": "Copyright © 2024-2026 Starizzi Technologies",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",

  "directories": {
    "output": "release",
    "buildResources": "build"
  },

  "files": [
    "dist/**/*",
    "!dist/renderer/**/*.map",
    "package.json"
  ],

  "extraResources": [
    {
      "from": "build/icon.ico",
      "to": "build/icon.ico"
    },
    {
      "from": "build/icon.png",
      "to": "build/icon.png"
    },
    {
      "from": "build/icon.icns",
      "to": "build/icon.icns"
    },
    {
      "from": "resources/bundled-extensions",
      "to": "bundled-extensions"
    }
  ],

  "beforePack": "scripts/before-pack.cjs",

  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "signAndEditExecutable": false
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Izzi OpenClaw",
    "deleteAppDataOnUninstall": false,
    "installerLanguages": ["en_US", "vi_VN"],
    "language": 1066
  },

  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.icns",
    "category": "public.app-category.developer-tools",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "darkModeSupport": true
  },

  "dmg": {
    "contents": [
      { "x": 130, "y": 180 },
      { "x": 410, "y": 180, "type": "link", "path": "/Applications" }
    ],
    "background": "build/dmg-background.png",
    "window": {
      "width": 540,
      "height": 380
    }
  },

  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "deb", "arch": ["x64"] },
      { "target": "rpm", "arch": ["x64"] }
    ],
    "icon": "build/icons",
    "category": "Development",
    "desktop": {
      "entry": {
        "Name": "Izzi OpenClaw",
        "Comment": "Smart AI assistant for every platform",
        "Terminal": "false"
      }
    },
    "synopsis": "AI-powered assistant desktop app"
  },

  "publish": {
    "provider": "github",
    "owner": "kentzu213",
    "repo": "starizzi-app",
    "releaseType": "release",
    "vPrefixedTagName": true
  },


  "extraMetadata": {
    "main": "dist/main/index.js"
  },

  "asar": true,
  "asarUnpack": [
    "node_modules/sharp/**/*",
    "node_modules/@napi-rs/**/*",
    "dist/main/extensions/extension-runner.js"
  ],

  "electronDownload": {
    "mirror": "https://npmmirror.com/mirrors/electron/"
  },

  "afterSign": null
}
