{
  "name": "starizzi-app",
  "version": "0.1.0",
  "private": true,
  "description": "Starizzi Multi-Agent Gateway — Desktop AI Agent Hub (OpenClaw, Hermes, AutoGPT…) connected to IzziAPI",
  "homepage": "https://github.com/kentzu213/starizzi-app#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kentzu213/starizzi-app.git"
  },
  "bugs": {
    "url": "https://github.com/kentzu213/starizzi-app/issues"
  },
  "author": "kentzu213",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "pnpm --filter @openclaw/desktop dev",
    "dev:marketplace": "pnpm --parallel --filter @openclaw/marketplace-api --filter @openclaw/desktop dev",
    "build": "pnpm --filter @openclaw/desktop build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "1.8.4"
    }
  }
}
